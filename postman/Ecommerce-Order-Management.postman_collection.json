{
  "info": {
    "name": "E-Commerce Order Management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for Spring Boot ecommerce-order-management APIs"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "adminToken", "value": "" },
    { "key": "customerToken", "value": "" },
    { "key": "warehouseToken", "value": "" },
    { "key": "productId", "value": "1" },
    { "key": "warehouseId", "value": "1" },
    { "key": "orderId", "value": "1" },
    { "key": "cartItemId", "value": "1" }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@shop.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Login Customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@shop.com\",\n  \"password\": \"customer123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"new@shop.com\",\n  \"password\": \"secret12\",\n  \"fullName\": \"New Customer\",\n  \"role\": \"CUSTOMER\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Wireless Mouse\",\n  \"description\": \"Ergonomic mouse\",\n  \"sku\": \"MOUSE-001\",\n  \"category\": \"Electronics\",\n  \"price\": 29.99,\n  \"active\": true\n}"
            },
            "url": "{{baseUrl}}/api/products"
          }
        },
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products"
          }
        }
      ]
    },
    {
      "name": "Warehouses",
      "item": [
        {
          "name": "Create Warehouse",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mumbai Hub\",\n  \"code\": \"MUM-01\",\n  \"location\": \"Mumbai, IN\",\n  \"active\": true\n}"
            },
            "url": "{{baseUrl}}/api/warehouses"
          }
        }
      ]
    },
    {
      "name": "Inventory",
      "item": [
        {
          "name": "Upsert Inventory",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{productId}},\n  \"warehouseId\": {{warehouseId}},\n  \"quantityAvailable\": 100\n}"
            },
            "url": "{{baseUrl}}/api/inventory"
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Add To Cart",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{productId}},\n  \"quantity\": 2\n}"
            },
            "url": "{{baseUrl}}/api/cart/add"
          }
        },
        {
          "name": "View Cart",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/api/cart"
          }
        },
        {
          "name": "Remove Cart Item",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/api/cart/remove/{{cartItemId}}"
          }
        }
      ]
    },
    {
      "name": "Checkout",
      "item": [
        {
          "name": "Checkout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shippingAddress\": \"12 MG Road, Bengaluru\",\n  \"paymentMethod\": \"CARD\",\n  \"discountCode\": \"SAVE10\"\n}"
            },
            "url": "{{baseUrl}}/api/checkout"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/api/orders"
          }
        },
        {
          "name": "Update Status PACKED",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{warehouseToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"PACKED\"\n}"
            },
            "url": "{{baseUrl}}/api/orders/{{orderId}}/status"
          }
        }
      ]
    },
    {
      "name": "Returns",
      "item": [
        {
          "name": "Create Return",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": {{orderId}},\n  \"reason\": \"Damaged on arrival\"\n}"
            },
            "url": "{{baseUrl}}/api/returns"
          }
        }
      ]
    }
  ]
}
